# Database Configuration
DB_PASSWORD=kingbot_secure_password
DATABASE_URL=postgresql://kingbot:kingbot_secure_password@postgres:5432/kingbot_platform

# Redis Configuration
REDIS_URL=redis://redis:6379

# JWT & Security
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRY=7d
ENCRYPTION_KEY=your_encryption_key_for_sensitive_data

# API Configuration
API_PORT=5000
API_HOST=0.0.0.0
NODE_ENV=development

# Trading Engine
TRADING_ENGINE_KEY=your_trading_engine_api_key
TRADING_ENGINE_PORT=5001
TRADING_ENGINE_URL=http://trading-engine:5001

# Broker Credentials (Encrypted in database)
MT5_DEMO_SERVER=demo.mt5.kingbot.tech
MT5_LIVE_SERVER=live.mt5.kingbot.tech

# Payment Configuration
PAYMENT_GATEWAY=stripe
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxx
STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxx
PAYMENT_WEBHOOK_SECRET=whsec_xxxxxxxxxx

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=noreply@kingbot.tech

# AI Support System
OPENAI_API_KEY=sk_xxxxxxxxxx
SUPPORT_MODEL=gpt-4

# TradingView API
TRADINGVIEW_TOKEN=your_tradingview_token

# AWS Configuration (Optional)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BUCKET=kingbot-storage

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_TRADING_ENGINE_URL=http://localhost:5001
NEXT_PUBLIC_STRIPE_KEY=pk_test_xxxxxxxxxx

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# Security
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX_REQUESTS=100

# Contact & Support
SUPPORT_PHONE=+27748275015
SUPPORT_EMAIL=support@kingbot.tech
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
